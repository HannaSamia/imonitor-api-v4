# ============================================
# iMonitor API v4 — Environment Variables
# ============================================
# Copy this file to .env and fill in the values.
# All variables match the v3 .env for compatibility.

# ---- Database Connection ----
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_PORT=3306

# Limited-privilege DB user (for native/restricted queries)
DB_LIMIT_USER=limituser
DB_LIMIT_PASSWORD=

# ---- Database Names ----
coreDbName=`iMonitorV3_1`
dataDbName=`iMonitorData`
etlDbName=`EtlV3_2`

# ---- Application ----
PORT=5011
CPUS=1

# ---- Authentication ----
JWT_KEY=your-jwt-secret-key

# ---- Email (SMTP) ----
MAIL_HOST=mail.example.com
MAIL_FROM=no-reply@example.com
MAIL_AUTH_EMAIL=user@example.com
MAIL_AUTH_PASSWROD=password

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Rate Limiting ----
NB_OF_REQUESTS=200
RATE_LIMIT_DURATION_SEC=60
RATE_BLOCK_DURATION=180
